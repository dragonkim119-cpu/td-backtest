# Binance Futures REST (public endpoints — no API key needed for klines)
# BINANCE_API_KEY=
# BINANCE_API_SECRET=

# Backend port (default: 8000)
# PORT=8000

# Telegram notifications (Phase 2)
# 1. BotFather에서 /newbot 으로 봇 생성 → TOKEN 발급
# 2. 봇에게 메시지 보낸 후 https://api.telegram.org/bot<TOKEN>/getUpdates 로 chat_id 확인
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
